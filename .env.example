PORT=3000
# Local dev: file:./data/dev.db  |  Docker: file:/app/data/dev.db
DATABASE_URL=file:/app/data/dev.db

TELEGRAM_BOT_TOKEN=

# Wallet private key for Polymarket CLOB (never commit real values)
PRIVATE_KEY=

# Skip signed orders; log only
DRY_RUN=true

# Optional overrides when Gamma search is unreliable
POLYMARKET_CONDITION_ID=
POLYMARKET_YES_TOKEN_ID=
POLYMARKET_NO_TOKEN_ID=

# Gamma API base (default used in code if unset)
GAMMA_API_URL=https://gamma-api.polymarket.com
